# ============================================================
# VED BAJAJ PORTFOLIO — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# ============================================================

# ─── SERVER ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── DATABASE ────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ved-portfolio?retryWrites=true&w=majority

# ─── AUTHENTICATION ──────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Secret required to register admin accounts
ADMIN_SECRET=your-admin-registration-secret

# Seed script admin credentials
ADMIN_EMAIL=ved@admin.com
ADMIN_PASSWORD=Admin@1234

# ─── EMAIL (SMTP) ─────────────────────────────────────────────
# Option A: Generic SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Option B: Gmail shortcut (if not using SMTP_HOST)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Where to send contact form notifications
OWNER_EMAIL=bajajved21@gmail.com

# ─── FRONTEND ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── AI / GROQ ──────────────────────────────────────────
# Used for the backend chat proxy route
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GITHUB ──────────────────────────────────────────────────
GITHUB_USERNAME=vedbajaj
# Optional: increases GitHub API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=info
